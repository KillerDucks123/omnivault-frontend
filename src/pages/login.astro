---
import "../styles/global.css";
---

<html lang="es">
<head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>OmniVault | Acceso</title>


    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

</head>
<body class="auth-bg">
    <div class="login-container" transition:animate="fade">
        <div class="auth-card">
            <div class="brand">
                <i class="bi bi-box-seam-fill logo-icon" transition:name="logo"></i>
                <h1>OmniVault</h1>
            </div>

            <form id="loginForm" class="auth-form">
                <div class="input-group">
                    <label>Email</label>
                    <input type="email" id="email" required placeholder="tu@email.com" />
                </div>
                <div class="input-group">
                    <label>Contraseña</label>
                    <input type="password" id="password" required placeholder="******" />
                </div>
                <button type="submit" id="btnIngresar" class="btn-primary">
                    Ingresar <i class="bi bi-arrow-right-short"></i>
                </button>
            </form>
            <p id="errorMsg" class="error-text"></p>
        </div>
    </div>

    <script src="../scripts/login.js"></script>

</body>
</html>